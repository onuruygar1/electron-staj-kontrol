{
  "name": "staj-kontrol-app",
  "version": "1.0.0",
  "description": "PDF transkriptinden Staj I ve Staj II uygunluk kontrolü yapan Electron uygulaması",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux --x64"
  },
  "build": {
    "appId": "com.stajkontrol.app",
    "productName": "BMNKU",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "logo.jpeg",
      "*.traineddata",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "pdf_parser.exe",
        "to": "pdf_parser.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "logo.jpeg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "logo.jpeg"
    },
    "linux": {
      "target": "AppImage",
      "icon": "logo.jpeg"
    }
  },
  "author": "IYTE",
  "dependencies": {
    "docx": "^9.6.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  }
}
